// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pegawai {
  id            Int      @id @default(autoincrement())
  notificationLogs NotificationLog[]
  nip           String   @unique
  nama          String
  pangkat       String
  golongan      String
  jabatan       String

  nomorHp       String?
  email         String? @unique

  nomorSk       String?
  tanggalSK     DateTime?
  tmtTerakhir   DateTime?

  kgb               Kgb[]
  pensiun           Pensiun[]
  kenaikanPangkat   KenaikanPangkat[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Kgb {
  id               Int      @id @default(autoincrement())

  pegawaiId        Int
  nomorSk          String
  tanggalSk        DateTime
  tmtKgb           DateTime
  gajiLama         Int
  gajiBaru         Int

  pegawai          Pegawai @relation(fields: [pegawaiId], references: [id])

  notificationLogs NotificationLog[]
}

model KenaikanPangkat {
  id              Int      @id @default(autoincrement())

  pegawaiId       Int
  pegawai         Pegawai @relation(fields: [pegawaiId], references: [id])

  pangkatBaru     String
  golonganBaru    String
  tmtKenaikan     DateTime

  notificationLog NotificationLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
model Pensiun {
  id               Int      @id @default(autoincrement())

  pegawaiId        Int
  tanggalPensiun   DateTime
  nomorSk          String?

  pegawai          Pegawai @relation(fields: [pegawaiId], references: [id])

  notificationLogs NotificationLog[]
}

model NotificationLog {
  id                  Int      @id @default(autoincrement())

  pegawaiId           Int
  kenaikanPangkatId   Int?
  kgbId               Int?
  pensiunId           Int?

  jenis               String

  source              String   @default("AUTO")

  createdAt           DateTime @default(now())

  pegawai             Pegawai            @relation(fields: [pegawaiId], references: [id])
  kenaikanPangkat     KenaikanPangkat?   @relation(fields: [kenaikanPangkatId], references: [id])
  kgb                 Kgb?               @relation(fields: [kgbId], references: [id])
  pensiun             Pensiun?           @relation(fields: [pensiunId], references: [id])

  @@unique([pegawaiId, kenaikanPangkatId, kgbId, pensiunId, jenis, source])
}